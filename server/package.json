{
  "name": "mcp-dashboards-server",
  "version": "0.1.0",
  "license": "Elastic-2.0",
  "type": "module",
  "scripts": {
    "postinstall": "bash scripts/sync-agent-skills.sh",
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx watch src/index.ts --http",
    "build": "tsc && cp -r src/resources/esql_docs dist/resources/esql_docs",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:stdio": "TRANSPORT=stdio vitest run --config vitest.integration.config.ts",
    "test:integration:http": "TRANSPORT=http vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:integration:9.3": "STACK_VERSION=9.3.0 npm run test:integration:stdio && STACK_VERSION=9.3.0 npm run test:integration:http",
    "test:integration:9.4": "STACK_VERSION=9.4.0-SNAPSHOT npm run test:integration:stdio && STACK_VERSION=9.4.0-SNAPSHOT npm run test:integration:http",
    "test:integration:all": "npm run test:integration:9.3 && npm run test:integration:9.4"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.0.0",
    "@elastic/esql": "^1.7.0",
    "@modelcontextprotocol/ext-apps": "^1.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "mcp-dashboards-shared": "*",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "puppeteer": "^24.0.0"
  },
  "devDependencies": {
    "@testcontainers/elasticsearch": "^11.14.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
